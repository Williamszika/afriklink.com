{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["fra1"],
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0",
      "memory": 512,
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/assets/(.*)", "dest": "/public/assets/$1", "headers": { "X-Content-Type-Options": "nosniff", "Strict-Transport-Security": "max-age=31536000; includeSubDomains" } },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ],
  "crons": [
    { "path": "/cron/relance-paniers", "schedule": "0 9 * * *" },
    { "path": "/cron/supervision", "schedule": "0 7 * * *" }
  ]
}
