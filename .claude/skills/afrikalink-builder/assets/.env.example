# .env.example — copier en .env (NE JAMAIS committer .env)
# Permissions recommandées sur le serveur : chmod 600 .env

APP_ENV=production          # production | local
APP_DEBUG=false
APP_URL=https://afrikalink.example
APP_KEY=                    # 32+ octets aléatoires (base64) — sel applicatif
DEFAULT_LOCALE=fr
DEFAULT_CURRENCY=EUR

# Base de données (compte applicatif à moindre privilège : pas de DDL en prod)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=afrikalink
DB_USER=afrikalink_app
DB_PASS=

# Stripe (clés restreintes par périmètre)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
PLATFORM_FEE_BPS=1000       # commission plateforme en points de base (1000 = 10%)

# E-mail transactionnel (SMTP ou API)
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=no-reply@afrikalink.example

# Alerting sécurité (réutiliser l'architecture Telegram existante si dispo)
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
