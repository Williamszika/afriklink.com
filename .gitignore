# Secrets — never commit
.env

# Composer dependencies (installed via `composer install`)
/vendor/

# Node / Playwright (tests e2e) — jamais versionnés
/node_modules/
/package-lock.json
/test-results/
/playwright-report/
/playwright/.cache/

# Runtime storage (logs, uploads, cache) — keep dirs, ignore contents
/storage/logs/*
/storage/uploads/*
/storage/cache/*
!/storage/logs/.gitkeep
!/storage/uploads/.gitkeep
!/storage/cache/.gitkeep

# Local build / editor noise
.DS_Store
Thumbs.db
*.log
.idea/
.vscode/
*.swp
