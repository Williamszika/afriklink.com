# AfriLink AI-Ops — copy to ai-ops/.env (NEVER commit .env)

# --- Anthropic API ---------------------------------------------------------
ANTHROPIC_API_KEY=                     # required to run agents (never hard-coded)
AFRILINK_DEFAULT_MODEL=claude-opus-4-8 # default model for every agent
AFRILINK_EFFORT=medium                 # low | medium | high | xhigh | max

# Per-agent model overrides (optional). Example: cheaper model for watch agents.
# AGENT_MODEL_MARKET_RESEARCH=claude-sonnet-4-6
# AGENT_MODEL_SECURITY_AUDIT=claude-opus-4-8
# AGENT_MODEL_COMPETITOR_WATCH=claude-haiku-4-5

# --- Web search (server tool) ---------------------------------------------
USE_WEB_SEARCH=true
WEB_SEARCH_MAX_USES=5                   # max searches per gather call

# --- Storage ---------------------------------------------------------------
# AFRILINK_DB_PATH=storage/afrilink.db
# AFRILINK_STORAGE_DIR=storage
# Repo the SecurityAuditAgent audits (defaults to the afriklink.com site repo root).
# AUDIT_REPO_PATH=/home/user/afriklink.com

# --- Cost guardrails (per agent run) --------------------------------------
MAX_API_CALLS_PER_RUN=8                 # global default call cap
MAX_TOKENS_PER_RUN=200000               # input+output token cap per run
MAX_SERVER_TOOL_TURNS=6                 # web-search pause/resume turns per gather
MAX_AGENT_RELAUNCHES=3                  # event-driven relaunch cap (senior_dev)
# MARKET_MAX_CALLS=12                    # market_research call cap (auto = #countries+3)
# SECURITY_MAX_CALLS=6
# SENIOR_DEV_MAX_CALLS=4
GATHER_MAX_TOKENS=10000
STRUCTURE_MAX_TOKENS=6000

# --- Market research scope -------------------------------------------------
# Comma-separated; defaults to the full West-Africa list. Trim to cut cost while testing.
# MARKET_COUNTRIES=Nigeria,Ghana,Sénégal
