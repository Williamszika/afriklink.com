# .env.example — copy to .env (NEVER commit .env)
# Recommended permissions on the server: chmod 600 .env

APP_ENV=production          # production | local
APP_DEBUG=false             # true only in local dev
APP_URL=https://afriklink.com
APP_KEY=                    # 32+ random bytes (base64) — application salt; run: php -r "echo base64_encode(random_bytes(32));"
                            # IMPORTANT : sert aussi à CHIFFRER les messages au repos (App\Services\Crypto).
                            # À garder secret et STABLE : la changer rend illisibles les messages déjà chiffrés.
DEFAULT_LOCALE=fr
DEFAULT_CURRENCY=EUR

# Proxys de CONFIANCE pour résoudre l'IP cliente (limitation de débit / audit).
# L'en-tête CF-Connecting-IP / X-Forwarded-For n'est honoré QUE si la requête
# provient d'un proxy de cette liste — sinon un client direct pourrait usurper
# son IP et contourner la limitation de débit. Laisser VIDE = plages Cloudflare
# par défaut. Derrière un AUTRE proxy (Vercel, nginx…), mettre ses CIDR ici.
TRUSTED_PROXIES=            # ex. 10.0.0.0/8,192.168.0.0/16  (vide = Cloudflare)

# Session storage: file | database. Auto-uses 'database' on Vercel (serverless
# filesystem is ephemeral). Leave unset locally to use file sessions.
# SESSION_DRIVER=database

# Database — application account (least privilege: SELECT/INSERT/UPDATE/DELETE only, no DDL in prod)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=afrikalink
DB_USER=afrikalink_app
DB_PASS=

# TLS for managed MySQL. TiDB Cloud Serverless REQUIRES TLS → set DB_SSL=true.
#   - Best: provide the CA bundle path so the server cert is verified.
#   - Fallback (if you can't supply a CA): DB_SSL_VERIFY=false.
# TiDB example: DB_HOST=gateway01.<region>.prod.aws.tidbcloud.com  DB_PORT=4000
#               DB_USER=<prefix>.root   DB_NAME=afrikalink
DB_SSL=false
DB_SSL_CA=                  # e.g. /etc/ssl/certs/ca-certificates.crt
DB_SSL_VERIFY=true

# Database — migration account (DDL rights). Used ONLY by database/migrate.php.
# Falls back to DB_USER/DB_PASS if left empty.
DB_DDL_USER=
DB_DDL_PASS=

# Stripe (restricted, scoped keys) — used from Phase 3 onward
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
PLATFORM_COMMISSION_PCT=5   # platform commission (%) taken on each transaction

# CinetPay — Mobile Money (Wave, Orange, MTN, Moov…) + cards, West Africa.
# Create a merchant account at cinetpay.com, then set both keys to go live;
# until then the order-payment flow runs in a no-charge "simulation" sandbox.
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
# PayPal (account + cards via PayPal)
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=

# Notifications SMS / WhatsApp to the seller on each new order. Drivers:
#   log (default) — writes to storage/logs/notify.log (no real message sent).
#   brevo_sms     — transactional SMS via Brevo (reuses MAIL_API_KEY, or set
#                   NOTIFY_API_KEY); NOTIFY_SMS_SENDER is the 3–11 char sender id.
#   twilio        — SMS via Twilio (TWILIO_SID, TWILIO_TOKEN, TWILIO_FROM).
#   whatsapp      — WhatsApp via Meta Cloud API (WHATSAPP_TOKEN, WHATSAPP_PHONE_ID).
NOTIFY_DRIVER=log           # log | brevo_sms | twilio | whatsapp
NOTIFY_API_KEY=             # falls back to MAIL_API_KEY when empty (Brevo)
NOTIFY_SMS_SENDER=Afriklink
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# Transactional e-mail. Drivers:
#   log  (default) — writes to storage/logs/mail.log (local dev only)
#   api            — HTTPS API via native cURL (RECOMMENDED on Vercel; no Composer).
#                    Free provider: Brevo (300 mails/day) → create an API key at
#                    app.brevo.com → SMTP & API → API Keys, and verify your sender
#                    address (Senders & Domains). Then set:
#                      MAIL_DRIVER=api
#                      MAIL_API_KEY=xkeysib-…
#                      MAIL_FROM=<your verified sender address>
#   smtp           — PHPMailer (requires composer install; fine on Hostinger)
MAIL_DRIVER=log             # log | api | smtp
MAIL_API_KEY=
# MAIL_API_URL=             # override only for a non-Brevo compatible API
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=no-reply@afriklink.com
MAIL_FROM_NAME=Afriklink

# Tâches planifiées (relance de panier abandonné). L'endpoint /cron/relance-paniers
# n'est actif que si CRON_SECRET est défini. L'authentification se fait UNIQUEMENT
# par l'en-tête « Authorization: Bearer $CRON_SECRET » (jamais en query string, qui
# fuiterait dans les journaux). Vercel Cron l'envoie automatiquement ; un
# planificateur externe doit ajouter cet en-tête à sa requête.
CRON_SECRET=
CART_REMIND_AFTER_MIN=120     # relancer après N minutes d'inactivité du panier
CART_REMIND_MAX_AGE_H=336     # ne pas relancer les paniers plus vieux que N heures (14 j)

# Traduction automatique du CONTENU vendeur (noms/descriptions de produits &
# boutiques) dans les 8 langues du site. Tant qu'aucune clé n'est fournie, le
# contenu reste dans la langue d'origine du vendeur (repli silencieux). Le
# pré-remplissage par lots se fait via le cron /cron/traduire-contenu (protégé
# par CRON_SECRET). Coût et qualité = ceux du fournisseur choisi.
TRANSLATE_API_KEY=            # clé API de traduction (repli sur ANTHROPIC_API_KEY si vide)
# ANTHROPIC_API_KEY=         # utilisable aussi pour la traduction (provider=anthropic)
TRANSLATE_PROVIDER=anthropic # fournisseur (anthropic par défaut)
TRANSLATE_MODEL=claude-haiku-4-5-20251001  # modèle (petit/rapide pour le coût)
TRANSLATE_CRON_MAX_ITEMS=20  # objets traités par exécution du cron
TRANSLATE_CRON_MAX_CALLS=80  # appels de traduction max par exécution (garde-fou coût)

# Vérification d'adresse (cohérence ville ↔ pays) par géocodage.
# Par défaut : OpenStreetMap / Nominatim — gratuit, sans clé. Best-effort et
# fail-open (ne bloque jamais la commande). Politique Nominatim : usage modéré +
# User-Agent identifiable avec contact RÉEL + attribution « © OpenStreetMap ».
GEOCODE_ENABLED=1            # 1 = actif (Nominatim), 0 = seulement le contrôle hors-ligne du code postal
GEOCODE_PROVIDER=nominatim
GEOCODE_ENDPOINT=https://nominatim.openstreetmap.org/search
GEOCODE_USER_AGENT=AfrikaLink/1.0 (+https://votre-domaine; contact@votre-domaine)  # METTRE un contact réel
GEOCODE_TIMEOUT=5

# Security alerting (reuse existing Telegram alert architecture if available)
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=

# Nettoyage AUTO des photos PRODUIT (détourage IA + fond neutre, façon catalogue).
# DÉSACTIVÉ par défaut → les photos sont servies telles quelles, aucun coût.
# L'activer (=1) EXIGE l'add-on « AI Background Removal » sur le compte Cloudinary
# (gratuit jusqu'à un quota, puis facturé à l'image). ⚠️ N'allumer qu'une fois
# l'add-on actif : sinon Cloudinary renvoie une erreur sur les photos produit.
# S'applique uniquement aux photos de produit boutique (jamais logos/bannières).
MEDIA_AUTOCLEAN=0           # 0 = aucun changement (défaut) ; 1 = détourage auto
MEDIA_AUTOCLEAN_BG=eef1f5   # couleur de fond (hex SANS #) après détourage (gris clair)

# ------------------------------------------------------------------------- #
# Identité légale de l'éditeur (mentions légales / Impressum, RGPD, CGV).
# Source unique : config/legal.php. Le contenu légal s'adapte au pays du
# visiteur (DE / UE / CI / international) ; ces variables remplissent les
# coordonnées RÉELLES de l'éditeur. À compléter avant exploitation, puis faire
# valider par un conseil juridique.
# ------------------------------------------------------------------------- #
LEGAL_NAME=                 # raison sociale (ex. Afriklink UG (haftungsbeschränkt))
LEGAL_FORM=                 # forme juridique (UG, GmbH, auto-entrepreneur…)
LEGAL_REP=                  # représentant légal / Geschäftsführer / directeur de publication
LEGAL_ADDRESS=              # rue + numéro
LEGAL_POSTAL=               # code postal
LEGAL_CITY=                 # ville
LEGAL_COUNTRY=DE            # pays d'établissement (ISO alpha-2) — détermine le régime « siège »
LEGAL_REGISTER=             # n° Handelsregister (HRB…) / RCCM
LEGAL_REGISTER_COURT=       # Amtsgericht … / Greffe du tribunal …
LEGAL_VAT=                  # USt-IdNr. / NIF (Compte contribuable)
LEGAL_PHONE=                # téléphone de contact (facultatif)
LEGAL_EMAIL=                # courriel légal/contact (défaut : MAIL_FROM)
LEGAL_DPO_EMAIL=            # délégué à la protection des données (si désigné)
