{
    "name": "afrikalink/afrikalink",
    "description": "AfrikaLink — international multi-vertical marketplace (shops, restaurants, salons, services). PHP 8.4 + MySQL 8.4, security-first.",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.4",
        "ext-pdo": "*",
        "ext-mbstring": "*",
        "ext-intl": "*",
        "ext-openssl": "*",
        "ext-fileinfo": "*",
        "vlucas/phpdotenv": "^5.6",
        "ramsey/uuid": "^4.7",
        "stripe/stripe-php": "^16.0",
        "phpmailer/phpmailer": "^6.9"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "migrate": "php database/migrate.php",
        "serve": "php -S 127.0.0.1:8000 -t public public/index.php"
    }
}
